#!/bin/bash
set -e

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Parse arguments
DEV_MODE=false
DEV_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dev)
      DEV_MODE=true
      if [[ -n "${2:-}" && "${2:0:1}" != "-" ]]; then
        DEV_NAME="$2"
        shift
      fi
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

echo "=== Agentic Federation Install ==="
echo ""

# CLI
echo "Installing CLI..."
cd "$REPO_DIR/cli"
npm install
npm run build

if [ "$DEV_MODE" = true ]; then
  # Dev mode: create symlink with branch-specific name
  if [ -z "$DEV_NAME" ]; then
    DEV_NAME="$(git -C "$REPO_DIR" rev-parse --abbrev-ref HEAD)"
  fi
  CMD_NAME="fed-${DEV_NAME}"
  NODE_BIN="$(npm prefix -g)/bin"
  TARGET="$REPO_DIR/cli/dist/index.js"

  chmod +x "$TARGET"
  ln -sf "$TARGET" "$NODE_BIN/$CMD_NAME"

  if command -v asdf &>/dev/null; then
    asdf reshim nodejs
  fi

  echo "  $CMD_NAME command installed globally."
  echo "  -> $TARGET"
else
  # Normal mode: npm link
  npm link
  echo "  fed command installed globally."
fi
echo ""

# Dashboard
echo "Installing Dashboard..."
cd "$REPO_DIR/dashboard"
npm install
npm run build
echo "  Dashboard built."
echo ""

# Cleanup broken symlinks in skills directory (normal mode only)
if [ "$DEV_MODE" = false ]; then
  for target_dir in "$HOME/.claude/skills"; do
    [ -d "$target_dir" ] || continue
    broken_count=0
    for link in "$target_dir"/*; do
      [ -L "$link" ] || continue
      if [ ! -e "$link" ]; then
        echo "  Removing broken symlink: $(basename "$link")"
        rm "$link"
        broken_count=$((broken_count + 1))
      fi
    done
    if [ "$broken_count" -gt 0 ]; then
      echo "  Removed $broken_count broken symlink(s) from $target_dir"
    fi
  done
  echo ""
fi

# Skills symlinks (normal mode only)
if [ "$DEV_MODE" = false ]; then
  SKILLS_SRC="$REPO_DIR/skills"
  SKILLS_DST="$HOME/.claude/skills"
  if [ -d "$SKILLS_SRC" ]; then
    echo "Linking skills..."
    mkdir -p "$SKILLS_DST"
    for skill_dir in "$SKILLS_SRC"/*/; do
      [ -d "$skill_dir" ] || continue
      skill_name="$(basename "$skill_dir")"
      ln -sfn "$skill_dir" "$SKILLS_DST/$skill_name"
      echo "  $skill_name -> $skill_dir"
    done
    echo ""
  fi
fi

# NOTE: Agent symlinks to ~/.claude/agents/ are no longer created.
# Agents are composed at session start via syncAgents() and dispatched
# via `fed prompt read` notifications from the workflow engine.

# PATH hint (normal mode only)
if [ "$DEV_MODE" = false ]; then
  if ! echo "$PATH" | tr ':' '\n' | grep -qx "$REPO_DIR/bin"; then
    echo "Add this to your shell profile (~/.zshrc or ~/.bashrc):"
    echo ""
    echo "  export PATH=\"$REPO_DIR/bin:\$PATH\""
    echo ""
  fi
fi

echo "=== Done ==="
echo ""
if [ "$DEV_MODE" = true ]; then
  echo "Dev command installed: $CMD_NAME"
  echo "To uninstall: bin/uninstall --dev ${DEV_NAME}"
else
  echo "Quick start:"
  echo "  fed init"
  echo "  fed repo add <name>"
  echo "  fed start <repo> <branch>"
fi
